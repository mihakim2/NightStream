{
  "name": "nightstream",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npx vite --host",
    "build": "cd client && npx vite build",
    "start": "npm run dev"
  },
  "dependencies": {
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "xml2js": "^0.6.2",
    "concurrently": "^8.2.2"
  }
}
